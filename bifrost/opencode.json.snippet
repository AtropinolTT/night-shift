{
  "//": "Bifrost — OpenCode plugin that bridges OpenCode agents to a FastMCP companion server",
  "plugin": [
    "bifrost-plugin"
  ],
  "mcp": {
    "bifrost-companion": {
      "type": "local",
      "//": "Path to the Python FastMCP companion entry point",
      "command": ["python3", "/absolute/path/to/bifrost/companion/server.py"],
      "enabled": true
    }
  }
}
